{
  "name": "@alternatefutures/e2ee",
  "version": "0.1.1",
  "description": "Framework-agnostic end-to-end-encryption core (Argon2id room derivation, AES-256-GCM, Ed25519 TOFU) shared across AlternateFutures clients.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "sideEffects": true,
  "engines": {
    "node": ">=18.18.2"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./wordlist": {
      "import": {
        "types": "./dist/wordlist.d.ts",
        "default": "./dist/wordlist.js"
      },
      "require": {
        "types": "./dist/wordlist.d.cts",
        "default": "./dist/wordlist.cjs"
      }
    },
    "./node": {
      "import": {
        "types": "./dist/node.d.ts",
        "default": "./dist/node.js"
      },
      "require": {
        "types": "./dist/node.d.cts",
        "default": "./dist/node.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "changeset": "changeset",
    "changeset:version": "changeset version && npm install --package-lock-only",
    "changeset:publish": "npm run build && changeset publish",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "hash-wasm": "^4.12.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.11",
    "@types/node": "^22.10.7",
    "tsup": "^8.3.5",
    "typescript": "~5.7.3",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alternatefutures/alternate-e2ee.git"
  }
}
